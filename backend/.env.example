# Railway inyecta esta variable automáticamente al agregar el plugin de PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/citas?schema=public"

# Genera un valor largo y aleatorio para producción, ej: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

PORT=3000

# Dominio de tu frontend, para CORS. En dev puedes dejar *
CORS_ORIGIN="*"

# Usados solo por el script de seed (prisma/seed.ts) para crear el primer admin
ADMIN_EMAIL="admin@clinica.com"
ADMIN_PASSWORD="CambiaEstaPassword123"
